<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Dubs Bad Hygiene Lite</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>
        <li Class="PatchOperationReplace">
          <xpath>Defs/CeleTech.ShuttleExtension.ModularShuttle.Defs.ShuttleHabitatModuleDef[defName="CT_Shuttle_BHLite_HygieneModule"]/playerInstallable</xpath>
          <value>
            <playerInstallable>true</playerInstallable>
          </value>
        </li>
        <li Class="PatchOperationAdd">
          <xpath>Defs/CeleTech.ShuttleExtension.ModularShuttle.Defs.ShuttleHabitatModuleDef[defName="CT_Shuttle_BHLite_HygieneModule"]</xpath>
          <value>
            <modExtensions>
              <li Class="CeleTech.ShuttleExtension.ModularShuttle.Extensions.ShuttleRuntimeSystemDefExtension">
                <runtimeSystemKey>celetech.shuttle.extension.additionalmodule/bhlite-hygiene-runtime</runtimeSystemKey>
              </li>
              <li Class="CeleTech.ShuttleExtension.AdditionalModule.Compatibility.BadHygieneLite.BHLiteHygieneModuleExtension">
                <integrationDefName>CT_Shuttle_BHLiteIntegration</integrationDefName>
              </li>
            </modExtensions>
          </value>
        </li>
      </operations>
    </match>
  </Operation>
</Patch>
